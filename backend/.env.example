DATABASE_URL=postgresql://postgres:postgres@localhost:5432/projectflux
PORT=3001
# Optional for separate frontend domains, comma-separated.
# Leave empty when serving the frontend from the same backend/domain.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional AI assist for communication log drafting.
# Gemini is recommended: free tier available at https://aistudio.google.com/apikey
# Add your key to backend/.env (this file is gitignored) then restart the server.
#
# Gemini (recommended – free tier, best quality, vision support):
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-lite
#
# OpenAI (fallback if no Gemini key is set):
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
